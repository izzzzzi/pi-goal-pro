{
  "name": "pi-goal-pro",
  "version": "1.1.0",
  "description": "Persistent autonomous goals for Pi — with no-progress detection, evidence-based completion, token budgets, and auto-continuation",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "files": [
    "index.ts",
    "README.md",
    "README.ru.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "goal",
    "autonomous",
    "agent",
    "coding-agent",
    "pi-goal",
    "pi-goal-pro",
    "goal-mode",
    "auto-continue",
    "no-progress-detection",
    "autonomous-agent",
    "pi-coding-agent"
  ],
  "license": "MIT",
  "author": "izzzzzi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izzzzzi/pi-goal-pro.git"
  },
  "bugs": {
    "url": "https://github.com/izzzzzi/pi-goal-pro/issues"
  },
  "homepage": "https://github.com/izzzzzi/pi-goal-pro#readme",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.78.0",
    "@earendil-works/pi-tui": ">=0.78.0",
    "@earendil-works/pi-ai": ">=0.78.0",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "typescript": "^5.8.0",
    "tsx": "^4.0.0"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/index.test.ts",
    "test:all": "npm run lint && npm run test:unit",
    "lint": "biome lint .",
    "check": "biome check .",
    "format": "biome format --write .",
    "dev": "pi -e ./index.ts"
  }
}
