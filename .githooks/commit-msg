#!/bin/sh
# commit-msg: enforce conventional commit format
MSG=$(cat "$1")
echo "$MSG" | grep -qE "^Merge branch|^Revert " && exit 0
echo "$MSG" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|chore|ci|build)(\(.+\))?!?: .+' || {
	echo ""
	echo "✗ Commit must follow conventional commit format:"
	echo "  type(scope): description"
	echo "  Types: feat, fix, docs, style, refactor, perf, test, chore, ci, build"
	echo "  First line MAX 72 chars. Append ! for breaking changes."
	echo ""
	echo "  Your message: $MSG"
	exit 1
}
exit 0
