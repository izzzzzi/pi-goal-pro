{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120,
		"indentWidth": 2
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "off"
			},
			"complexity": {
				"noBannedTypes": "warn",
				"noExcessiveCognitiveComplexity": "warn"
			}
		}
	},
	"files": {
		"includes": ["**/index.ts", "**/tests/**/*.ts", "!**/node_modules", "!**/dist"]
	}
}
